<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.hdm.capitec-pull</string>

    <key>ProgramArguments</key>
    <array>
        <string>/Users/clivefigueira/CapitecCardPull/.venv/bin/python</string>
        <string>-m</string>
        <string>capitec_pull.pull</string>
    </array>

    <key>WorkingDirectory</key>
